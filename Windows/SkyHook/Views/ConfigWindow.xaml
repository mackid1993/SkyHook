<Window x:Class="SkyHook.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SkyHook" Width="720" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Tab buttons at top -->
                <StackPanel DockPanel.Dock="Top" Margin="8,8,8,0">
                    <Button x:Name="RemotesTabBtn" Content="Remotes" Style="{StaticResource FluentButton}"
                            HorizontalContentAlignment="Left" Margin="0,2" Click="RemotesTab_Click"/>
                    <Button x:Name="SettingsTabBtn" Content="Settings" Style="{StaticResource FluentButton}"
                            HorizontalContentAlignment="Left" Margin="0,2" Click="SettingsTab_Click"/>
                </StackPanel>

                <!-- Remote list (visible when Remotes tab active) -->
                <DockPanel x:Name="RemoteListPanel">
                    <StackPanel DockPanel.Dock="Bottom" Margin="8" Orientation="Horizontal">
                        <Button Content="+" Style="{StaticResource FluentButton}" Padding="8,4" FontSize="16" Click="AddRemote_Click"/>
                        <Button Content="-" Style="{StaticResource FluentButton}" Padding="8,4" FontSize="16" Margin="4,0,0,0" Click="DeleteRemote_Click"/>
                    </StackPanel>
                    <ListBox x:Name="RemoteList" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource FgBrush}" FontSize="13"
                             SelectionChanged="RemoteList_SelectionChanged" Margin="4"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel x:Name="ContentPanel" Margin="8"/>
        </ScrollViewer>
    </Grid>
</Window>
