<Window x:Class="SkyHook.Views.SetupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Setup" Width="480" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">
    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock x:Name="TitleText" Text="Setting up remote..." FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource FgBrush}"/>
                <TextBlock x:Name="StatusText" Text="Starting..." FontSize="12"
                           Foreground="{StaticResource FgSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource FluentButton}" Padding="16,6" Click="Cancel_Click"/>
                <Button x:Name="DoneButton" Content="Done" Style="{StaticResource AccentButton}"
                        Padding="16,6" Margin="8,0,0,0" Visibility="Collapsed" Click="Done_Click"/>
            </StackPanel>

            <!-- Prompt Area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PromptPanel" Margin="0,8"/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
