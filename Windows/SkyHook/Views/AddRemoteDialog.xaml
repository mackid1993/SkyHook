<Window x:Class="SkyHook.Views.AddRemoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Remote" Width="420" Height="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">
    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <DockPanel>
            <!-- Header -->
            <TextBlock DockPanel.Dock="Top" Text="Add Remote" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrush}" Margin="0,0,0,16"/>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource FluentButton}" Padding="16,6" Click="Cancel_Click"/>
                <Button x:Name="AddButton" Content="Add Remote" Style="{StaticResource AccentButton}"
                        Padding="16,6" Margin="8,0,0,0" Click="Add_Click"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Margin="0,8">
                <!-- Name -->
                <TextBlock Text="Remote Name" FontSize="12" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Style="{StaticResource FluentTextBox}" Margin="0,0,0,12"/>

                <!-- Provider -->
                <TextBlock Text="Provider" FontSize="12" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="ProviderCombo" Style="{StaticResource FluentComboBox}" Margin="0,0,0,12"/>

                <!-- Auto-mount -->
                <CheckBox x:Name="AutoMountCheck" Content="Auto-mount at startup"
                          Foreground="{StaticResource FgBrush}" FontSize="12" Margin="0,0,0,12"/>

                <!-- Info -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="6" Padding="10,8" Margin="0,4">
                    <TextBlock x:Name="InfoText" FontSize="11" Foreground="{StaticResource FgTertiaryBrush}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
