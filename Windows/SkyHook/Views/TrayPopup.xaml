<Window x:Class="SkyHook.Views.TrayPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Width="320" Height="420" Title="SkyHook">
    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="0">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#xE753;" FontFamily="Segoe Fluent Icons"
                               FontSize="18" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="SkyHook" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="VersionText" FontSize="11" Foreground="{StaticResource FgTertiaryBrush}" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <Button x:Name="UpdateButton" DockPanel.Dock="Right" Content="Update" Style="{StaticResource AccentButton}"
                            Padding="8,3" FontSize="11" Visibility="Collapsed" VerticalAlignment="Center" Click="UpdateButton_Click"/>
                </DockPanel>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Content="Configure..." Style="{StaticResource FluentButton}"
                            FontSize="12" Padding="10,4" Click="Configure_Click"/>
                    <Button DockPanel.Dock="Right" Content="Quit" Style="{StaticResource FluentButton}"
                            FontSize="12" Padding="10,4" Click="Quit_Click"/>
                    <TextBlock x:Name="StatusText" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource FgTertiaryBrush}" FontFamily="Segoe UI"/>
                </DockPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel x:Name="ContentPanel" Margin="4">
                    <!-- Populated in code-behind based on state -->
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
